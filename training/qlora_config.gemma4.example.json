{
  "base_model": "google/gemma-4-E2B-it",
  "dataset_path": "../../data/traning/combined_training_sft.jsonl",
  "output_dir": "./outputs/gemma4-herbal-qlora",
  "max_seq_length": 1024,
  "num_train_epochs": 3,
  "per_device_train_batch_size": 1,
  "gradient_accumulation_steps": 8,
  "learning_rate": 0.0002,
  "lora_r": 16,
  "lora_alpha": 32,
  "lora_dropout": 0.05,
  "gradient_checkpointing": true,
  "warmup_ratio": 0.03,
  "max_grad_norm": 0.3,
  "save_total_limit": 2,
  "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"]
}
